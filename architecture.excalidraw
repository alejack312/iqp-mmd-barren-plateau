      "strokeColor": "#2563eb",
      "strokeWidth": 2,
      "roughness": 1,
      "opacity": 100,
      "roundness": { "type": 3 },
      "label": {
        "text": "src/iqp_mmd/   (modular toolkit)\n\nmodels/    sklearn IqpSimulator wrapper\ntraining/  wraps iqpopt Trainer + mmd_loss_iqp\nsampling/  unified sampler for all model types\ndatasets/  loaders (Ising, MNIST, genomic...)\nmetrics/   MMD + KGEL evaluation\ncli/       iqp-train / iqp-sample / iqp-evaluate\nconfigs/   hyperparameters.yaml (from paper)",
        "fontSize": 15,
        "fontFamily": 1
      }
    },
    {
      "type": "rectangle",
      "id": "iqp_bp",
      "x": 600,
      "y": 498,
      "width": 555,
