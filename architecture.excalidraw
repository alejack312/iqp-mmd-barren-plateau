      "strokeColor": "#16a34a",
      "strokeWidth": 2,
      "roughness": 1,
      "opacity": 100,
      "roundness": { "type": 3 },
      "label": {
        "text": "src/iqp_bp/   (barren plateau research -- ours)\n\niqp/expectation.py   pure NumPy cosine formula\niqp/model.py         IQPModel class\nmmd/loss.py          MMD2 estimator\nmmd/kernel.py        Gaussian, Laplacian, Poly, Linear\nmmd/gradients.py     gradient variance\nhypergraph/families  F1-F6 circuit families\nexperiments/         scaling experiment runners",
        "fontSize": 15,
        "fontFamily": 1
