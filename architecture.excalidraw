      "strokeWidth": 2,
      "roughness": 1,
      "opacity": 100,
      "roundness": { "type": 3 },
      "label": {
        "text": "scaling-gqml  @  b907bb1\ngithub.com/XanaduAI/scaling-gqml\narXiv:2503.02934\n\npaper/training/train_iqp.py\npaper/datasets/\n  Ising, genomic, D-Wave, MNIST, blobs\nconfigs/best_hyperparameters.yaml\npaper/plots/calc_grads.py",
        "fontSize": 15,
        "fontFamily": 1
      }
