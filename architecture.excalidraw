      "roughness": 1,
      "opacity": 100,
      "roundness": { "type": 3 },
      "label": {
        "text": "iqpopt  (pip install iqpopt)\ngithub.com/XanaduAI/iqpopt\n\nIqpSimulator\n  op_expval_batch()  cosine MC\n  sample()  PennyLane / JAX\n  iqp_circuit()  H + MultiRZ + H\n\nTrainer  (JAX + Adam / BFGS)\nmmd_loss_iqp  (training loss)\ngaussian_kernel",
        "fontSize": 15,
        "fontFamily": 1
      }
    },
    {
      "type": "rectangle",
      "id": "sgqml",
      "x": 398,
      "y": 58,
      "width": 403,
      "height": 358,
